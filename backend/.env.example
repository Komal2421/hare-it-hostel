# Postgres connection (node-postgres)
DATABASE_URL=postgresql://USER@localhost:5432/hare_it_db

# Auth — generate a long random string for production
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_EXPIRES_IN=7d

# Server
PORT=8000

# CORS: comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Public base URL of this API (used to build image URLs)
PUBLIC_BASE_URL=http://localhost:8000
